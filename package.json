{
  "name": "universal-scheme-validator",
  "version": "0.0.1",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "files": [
    "dist/**/*",
    "*.md"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "dev": "nodemon src/index.ts --exec ts-node --respawn",
    "prepare": "husky install",
    "format": "prettier --write \"src/**/*.ts\"",
    "format:check": "prettier --check \"src/**/*.ts\""
  },
  "keywords": [
    "package",
    "validator",
    "validation",
    "typescript",
    "validator-scheme",
    "validator-node"
  ],
  "author": "Seerendo",
  "license": "MIT",
  "description": "Validation schemas for class-based data models",
  "devDependencies": {
    "husky": "^8.0.0",
    "lint-staged": "^16.4.0",
    "prettier": "^3.8.3",
    "ts-node": "^10.9.2",
    "typescript": "^5.7.3"
  },
  "lint-staged": {
    "src/**/*.ts": [
      "prettier --write"
    ]
  },
  "repository": {
    "url": "https://github.com/Seerendo/universal-scheme-validator.git",
    "type": "git"
  },
  "bugs": {
    "url": "https://github.com/Seerendo/universal-scheme-validator/issues"
  },
  "homepage": "https://github.com/Seerendo/universal-scheme-validator#readme"
}
